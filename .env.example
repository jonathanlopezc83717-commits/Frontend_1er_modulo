# Variables de entorno para Supabase Local
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=tu-anon-key-de-supabase-local

# OpenRouter API Key
VITE_OPENROUTER_API_KEY=tu-api-key-de-openrouter

# Watcher de carpeta local sincronizada por Synology Drive
# Ejemplo Windows: C:\Users\TU_USUARIO\SynologyDrive\Obras
NAS_WATCH_PATH=
NAS_WATCH_INTERVAL_MS=5000
NAS_WATCH_HASH_LIMIT_MB=50
