{"ts":"2026-07-01T18:12:00.863Z","sessionID":"ses_0e13505afffeVP3YMJGltQ2SU9","agent":"build","tool":"bash","command":"node --input-type=module -e \"\nimport { readFileSync } from 'fs';\nimport * as XLSX from 'xlsx';\nconst buf = readFileSync('.swarm/ejemplo-emma.csv');\nconst ab = buf.buffer.slice(buf.byteOffset, buf.byteOffset + buf.byteLength);\n\n// 1) parsearExcelSincronizacion (saltarEncabezado=false)\nconst wb = XLSX.read(ab, { type: 'array' });\nconst ws = wb.Sheets[wb.SheetNames[0]];\nconst rows = XLSX.utils.sheet_to_json(ws, { header: 1, defval: '' });\nconsole.log('Filas crudas leidas por xlsx:', rows.length);\nconsole.log('Primera fila cruda:', JSON.stringify(rows[0]));\nconsole.log('Ultima fila cruda:', JSON.stringify(rows[rows.length-1]));\n\n// 2) parsearCSV preview (texto)\nconst texto = new TextDecoder().decode(ab);\nconst lineas = texto.replace(/\\r\\n/g,'\\n').split('\\n').filter(l=>l.trim()!=='');\nconsole.log('Lineas de texto:', lineas.length);\nconsole.log('Fila que parsearCSV usaria de encabezado:', JSON.stringify(lineas[0]));\n\"\n"}
